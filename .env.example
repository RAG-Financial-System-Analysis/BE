# ============================================================
# Sao chép file này thành .env và điền giá trị thực vào
# cp .env.example .env
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
DB_NAME=RAG-System
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_PORT=5432

# ── Backend port ─────────────────────────────────────────────
BACKEND_PORT=8080

# ── AWS Cognito / S3 ─────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_USER_POOL_ID=ap-southeast-1_XXXXXXXX
AWS_CLIENT_ID=your_cognito_client_id
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_AUTHORITY=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_XXXXXXXX
AWS_S3_BUCKET=your-s3-bucket-name

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKEN=1000
