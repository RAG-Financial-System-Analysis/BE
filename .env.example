# ============================================================================
# RAG System Docker Environment Configuration
# ============================================================================
# Copy this file to .env and update the values for your environment
# This file contains all the environment variables needed for Docker deployment

# ============================================================================
# BASIC CONFIGURATION
# ============================================================================

# Build configuration (Release for production, Debug for development)
BUILD_CONFIGURATION=Release

# ASP.NET Core environment (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# Backend port mapping (host:container)
BACKEND_PORT=8080

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL database settings
DB_NAME=RAG-System
DB_USER=postgres
DB_PASSWORD=123456
DB_PORT=5432

# ============================================================================
# AWS CONFIGURATION
# ============================================================================

# AWS region
AWS_REGION=ap-southeast-1

# AWS Cognito settings
AWS_USER_POOL_ID=your-user-pool-id
AWS_CLIENT_ID=your-client-id
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_AUTHORITY=https://cognito-idp.ap-southeast-1.amazonaws.com/your-user-pool-id
AWS_S3_BUCKET=your-s3-bucket-name

# ============================================================================
# AI CONFIGURATION (GEMINI - PRIMARY)
# ============================================================================

# Google Gemini API settings (currently used)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=models/gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1
GEMINI_TIMEOUT_MINUTES=10

# ============================================================================
# AI CONFIGURATION (OPENAI - BACKUP)
# ============================================================================

# OpenAI API settings (commented out, kept for rollback)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKEN=1000

# ============================================================================
# RAG SYSTEM CONFIGURATION
# ============================================================================

# RAG system settings
RAG_TIMEOUT_MINUTES=10
RAG_MAX_FILE_SIZE_MB=100

# ============================================================================
# USER ACCOUNTS CONFIGURATION
# ============================================================================

# Default admin user
ADMIN_EMAIL=admin@rag.com
ADMIN_PASSWORD=Admin@123!!
ADMIN_FULLNAME=System Admin

# Default analyst user
ANALYST_EMAIL=analyst@rag.com
ANALYST_PASSWORD=Analyst@123!!
ANALYST_FULLNAME=System Analyst

# ============================================================================
# OPTIONAL SERVICES (UNCOMMENT TO ENABLE)
# ============================================================================

# Redis cache settings (for future scaling)
# REDIS_PORT=6379

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Set to true for development mode with hot reload
# DEVELOPMENT_MODE=true

# Enable detailed logging for debugging
# ENABLE_DEBUG_LOGGING=true

# ============================================================================
# PRODUCTION SETTINGS
# ============================================================================

# For production deployment, consider these settings:
# BUILD_CONFIGURATION=Release
# ASPNETCORE_ENVIRONMENT=Production
# RAG_TIMEOUT_MINUTES=30
# RAG_MAX_FILE_SIZE_MB=500

# ============================================================================
# SECURITY NOTES
# ============================================================================

# IMPORTANT: 
# 1. Never commit .env file to version control
# 2. Use strong passwords for production
# 3. Rotate API keys regularly
# 4. Use AWS IAM roles instead of access keys when possible
# 5. Enable HTTPS in production