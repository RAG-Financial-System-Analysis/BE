# RAG System Deployment Configuration - EXAMPLE
# Copy this file to deployment-config.env and fill in your actual values
# Updated for new features and API endpoints

# ===== BASIC SETTINGS =====
ENVIRONMENT=dev
PROJECT_NAME=myragapp
AWS_DEFAULT_REGION=ap-southeast-1

# ===== APPLICATION CONFIGURATION =====
ALLOWED_HOSTS=*

# ===== DATABASE CONFIGURATION =====
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=RAGSystem
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
CONNECTION_STRING=Host=your-rds-endpoint.region.rds.amazonaws.com;Port=5432;Database=RAGSystem;Username=postgres;Password=your-db-password

# ===== LAMBDA CONFIGURATION =====
LAMBDA_RUNTIME=dotnet10
LAMBDA_MEMORY_SIZE=1024
LAMBDA_TIMEOUT=60
LAMBDA_HANDLER=RAG.APIs::RAG.APIs.LambdaEntryPoint::FunctionHandlerAsync

# ===== RDS CONFIGURATION =====
RDS_INSTANCE_CLASS=db.t3.small
RDS_ALLOCATED_STORAGE=50
RDS_MAX_ALLOCATED_STORAGE=200
RDS_ENGINE_VERSION=16.6
RDS_BACKUP_RETENTION_PERIOD=7
RDS_MULTI_AZ=false
RDS_STORAGE_ENCRYPTED=true
RDS_PUBLICLY_ACCESSIBLE=true

# ===== API GATEWAY CONFIGURATION =====
API_GATEWAY_STAGE=production
API_GATEWAY_DESCRIPTION=RAG System API Gateway with AI Integration
API_GATEWAY_LOGGING_ENABLED=true
API_GATEWAY_THROTTLE_RATE=2000
API_GATEWAY_THROTTLE_BURST=5000

# ===== AI SERVICES CONFIGURATION =====
# OpenAI Configuration
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_TOKENS=1000

# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=models/gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1
GEMINI_TIMEOUT_MINUTES=30

# ===== RAG SYSTEM CONFIGURATION =====
RAG_REQUEST_TIMEOUT_MINUTES=25
RAG_MAX_FILE_SIZE_MB=100

# ===== FILE UPLOAD CONFIGURATION =====
FILE_UPLOAD_MAX_SIZE_MB=100

# ===== AWS CONFIGURATION =====
AWS_USER_POOL_ID=your-cognito-user-pool-id
AWS_CLIENT_ID=your-cognito-client-id
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_AUTHORITY=https://cognito-idp.your-region.amazonaws.com/your-user-pool-id
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# ===== DEFAULT USERS CONFIGURATION =====
ADMIN_USER_EMAIL=admin@yourdomain.com
ADMIN_USER_PASSWORD=YourSecureAdminPassword
ADMIN_USER_FULLNAME=System Admin

ANALYST_USER_EMAIL=analyst@yourdomain.com
ANALYST_USER_PASSWORD=YourSecureAnalystPassword
ANALYST_USER_FULLNAME=System Analyst

# ===== DEPLOYMENT OPTIONS =====
SKIP_TESTS=false
SKIP_SEEDING=false
SKIP_CLEANUP=false
VERBOSE_LOGGING=true

# ===== COST OPTIMIZATION =====
AUTO_CLEANUP_RESOURCES=false
USE_SPOT_INSTANCES=false

# ===== SECURITY SETTINGS =====
ENABLE_VPC=false
VPC_CIDR_BLOCK=10.0.0.0/16
RDS_SSL_ENABLED=true

# ===== MONITORING AND LOGGING =====
CLOUDWATCH_LOG_RETENTION_DAYS=30
ENABLE_DETAILED_MONITORING=true
ENABLE_XRAY_TRACING=true

# ===== ADVANCED SETTINGS =====
CUSTOM_DOMAIN_NAME=
SSL_CERTIFICATE_ARN=
CUSTOM_TAGS=Environment=$ENVIRONMENT,Project=$PROJECT_NAME,Service=RAG-System